---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectRow from '../../components/ProjectRow.astro';
import { pinnedThenByDate } from '../../lib/content';

const projects = pinnedThenByDate(await getCollection('projects'), 'date');
---

<BaseLayout title="Projects" description="Things I've built and tinkered with.">
	<h1 class="text-2xl font-bold">Projects</h1>
	<p class="mt-1 text-zinc-600 dark:text-zinc-400">
		A running list of things I've built and tinkered with.
	</p>
	<div class="mt-6">
		{projects.map((p) => <ProjectRow project={p} />)}
	</div>
</BaseLayout>
