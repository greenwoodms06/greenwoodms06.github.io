---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorshipBadge from '../../components/AuthorshipBadge.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import {
	displayTags,
	isPublished,
	sortByDateDesc,
	readingTime,
} from '../../lib/content';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((p) => ({
		params: { slug: p.id },
		props: { project: p },
	}));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const minutes = readingTime(project.body ?? '');
const { title, summary, thumbnail, repo, demo, authorship, relatedPosts } =
	project.data;
const allTags = displayTags(project);
const writing = relatedPosts.length
	? sortByDateDesc(
			(await getCollection('posts')).filter(
				(p) => relatedPosts.includes(p.id) && isPublished(p),
			),
			'pubDate',
		)
	: [];
---

<BaseLayout title={title} description={summary} image={thumbnail}>
	<div
		class="mx-auto grid max-w-5xl grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_13rem]"
	>
		<article class="prose-measure mx-auto w-full min-w-0">
			<a href="/projects" class="text-sm text-zinc-500 hover:text-accent"
				>← projects</a
			>
		<h1 class="mt-2 text-3xl font-bold">{title}</h1>
		<p class="mt-1 text-zinc-600 dark:text-zinc-400">{summary}</p>
		{
			(repo || demo) && (
				<div class="mt-4 flex flex-wrap gap-3">
					{repo && (
						<a
							href={repo}
							class="inline-flex items-center gap-1.5 rounded-lg bg-accent px-3 py-1.5 text-sm font-medium text-white transition hover:opacity-90"
						>
							View repo ↗
						</a>
					)}
					{demo && (
						<a
							href={demo}
							class="inline-flex items-center gap-1.5 rounded-lg border border-accent px-3 py-1.5 text-sm font-medium text-accent transition hover:bg-accent/10"
						>
							Live demo ↗
						</a>
					)}
				</div>
			)
		}
		<div class="mt-3 flex flex-wrap gap-3 text-sm">
			{
				allTags.map((t) => (
					<a href={`/tags/${t}`} class="text-zinc-500 hover:text-accent">
						#{t}
					</a>
				))
			}
		</div>
		<AuthorshipBadge authorship={authorship} variant="note" />
		{
			thumbnail && (
				<Image
					src={thumbnail}
					alt={title}
					widths={[800, 1200, 1800, 2400]}
					class="mt-6 rounded-xl"
				/>
			)
		}
		<div class="prose prose-zinc mt-8 max-w-none dark:prose-invert">
			<Content />
		</div>

		<script>
			// Make article images expandable — click opens the loaded resolution in a new tab.
			document
				.querySelectorAll<HTMLImageElement>('article img')
				.forEach((img) => {
					if (img.closest('a')) return;
					const a = document.createElement('a');
					a.href = img.currentSrc || img.src;
					a.target = '_blank';
					a.rel = 'noopener';
					a.title = 'Open full size';
					a.style.cursor = 'zoom-in';
					a.style.display = 'block';
					img.parentNode?.insertBefore(a, img);
					a.appendChild(img);
				});
		</script>
		{
			writing.length > 0 && (
				<div class="mt-8 border-t border-zinc-200 pt-4 dark:border-zinc-800">
					<h2 class="text-sm font-semibold text-zinc-500">Writing about this</h2>
					<ul class="mt-2 space-y-3">
						{writing.map((p) => (
							<li>
								<div class="flex flex-wrap items-baseline gap-x-2">
									<a
										href={`/blog/${p.id}`}
										class="text-accent hover:underline"
									>
										{p.data.title}
									</a>
									<span class="font-mono text-xs text-zinc-500">
										<FormattedDate date={p.data.pubDate} /> · {p.data.kind}
									</span>
								</div>
								<p class="mt-0.5 text-sm text-zinc-600 dark:text-zinc-400">
									{p.data.description}
								</p>
							</li>
						))}
					</ul>
				</div>
			)
		}
		</article>
		<aside class="hidden lg:block">
			<TableOfContents headings={headings} minutes={minutes} />
		</aside>
	</div>
</BaseLayout>
