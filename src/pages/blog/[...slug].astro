---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import AuthorshipBadge from '../../components/AuthorshipBadge.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { displayTags, readingTime } from '../../lib/content';

export async function getStaticPaths() {
	const posts = (await getCollection('posts')).filter(
		(p) => !p.data.draft || import.meta.env.DEV,
	);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? '');
const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	relatedProjects,
	authorship,
} = post.data;
const related = relatedProjects.length
	? (await getCollection('projects')).filter((p) =>
			relatedProjects.includes(p.id),
		)
	: [];
const allTags = displayTags(post);
---

<BaseLayout title={title} description={description} image={heroImage}>
	<div
		class="mx-auto grid max-w-5xl grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1fr)_13rem]"
	>
		<article class="prose-measure mx-auto w-full min-w-0">
			<a href="/blog" class="text-sm text-zinc-500 hover:text-accent">← writing</a>
		<h1 class="mt-2 text-3xl font-bold">{title}</h1>
		<p class="mt-1 font-mono text-xs text-zinc-500">
			<FormattedDate date={pubDate} />
			{
				updatedDate && (
					<span>
						{' '}
						· updated <FormattedDate date={updatedDate} />
					</span>
				)
			}
		</p>
		<AuthorshipBadge authorship={authorship} variant="note" />
		{
			heroImage && (
				<Image
					src={heroImage}
					alt={title}
					widths={[800, 1200, 1800, 2400]}
					class="mt-6 rounded-xl"
				/>
			)
		}
		<div class="prose prose-zinc mt-8 max-w-none dark:prose-invert">
			<Content />
		</div>

		<script>
			// Make article images expandable — click opens the loaded resolution in a new tab.
			document
				.querySelectorAll<HTMLImageElement>('article img')
				.forEach((img) => {
					if (img.closest('a')) return;
					const a = document.createElement('a');
					a.href = img.currentSrc || img.src;
					a.target = '_blank';
					a.rel = 'noopener';
					a.title = 'Open full size';
					a.style.cursor = 'zoom-in';
					a.style.display = 'block';
					img.parentNode?.insertBefore(a, img);
					a.appendChild(img);
				});
		</script>
		{
			allTags.length > 0 && (
				<div class="mt-8 flex flex-wrap gap-2 text-sm">
					{allTags.map((t) => (
						<a href={`/tags/${t}`} class="text-zinc-500 hover:text-accent">
							#{t}
						</a>
					))}
				</div>
			)
		}
		{
			related.length > 0 && (
				<div class="mt-8 border-t border-zinc-200 pt-4 dark:border-zinc-800">
					<h2 class="text-sm font-semibold text-zinc-500">Related projects</h2>
					<ul class="mt-2 list-disc pl-5">
						{related.map((p) => (
							<li>
								<a
									href={`/projects/${p.id}`}
									class="text-accent hover:underline"
								>
									{p.data.title}
								</a>
							</li>
						))}
					</ul>
				</div>
			)
		}
		</article>
		<aside class="hidden lg:block">
			<TableOfContents headings={headings} minutes={minutes} />
		</aside>
	</div>
</BaseLayout>
