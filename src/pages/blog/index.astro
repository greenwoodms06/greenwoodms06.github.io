---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostListItem from '../../components/PostListItem.astro';
import { pinnedThenByDate, isPublished } from '../../lib/content';

const posts = pinnedThenByDate(
	(await getCollection('posts')).filter(isPublished),
	'pubDate',
);

const chips = [
	{ value: 'all', label: 'All' },
	{ value: 'essay', label: 'Essays' },
	{ value: 'musing', label: 'Musings' },
];
---

<BaseLayout
	title="Writing"
	description="Essays and musings — the occasional rabbit hole."
>
	<h1 class="text-2xl font-bold">Writing</h1>
	<p class="mt-1 text-zinc-600 dark:text-zinc-400">
		Essays and musings — the occasional rabbit hole.
	</p>

	<div class="mt-5 flex gap-2" role="group" aria-label="Filter writing by kind">
		{
			chips.map((c) => (
				<button
					type="button"
					data-filter={c.value}
					aria-pressed={c.value === 'all' ? 'true' : 'false'}
					class="kind-chip rounded-full border border-zinc-300 px-3 py-1 text-sm transition hover:border-accent aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-white dark:border-zinc-700"
				>
					{c.label}
				</button>
			))
		}
	</div>

	<div class="mt-4" id="writing-list">
		{posts.map((p) => <PostListItem post={p} />)}
	</div>
</BaseLayout>

<script>
	const chips = document.querySelectorAll<HTMLButtonElement>('.kind-chip');
	const items = document.querySelectorAll<HTMLElement>('#writing-list [data-kind]');
	chips.forEach((chip) => {
		chip.addEventListener('click', () => {
			const want = chip.dataset.filter;
			chips.forEach((c) =>
				c.setAttribute('aria-pressed', String(c === chip)),
			);
			items.forEach((el) => {
				const show = want === 'all' || el.dataset.kind === want;
				el.classList.toggle('hidden', !show);
			});
		});
	});
</script>
