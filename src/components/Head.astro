---
import '../styles/global.css';
import { Font } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: ImageMetadata | string;
}

const { title, description = SITE_DESCRIPTION, image } = Astro.props;
const pageTitle = title
	? `${title} · ${SITE_TITLE}`
	: `${SITE_TITLE} — ${SITE_TAGLINE}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageSrc = typeof image === 'string' ? image : (image?.src ?? FallbackImage.src);
const ogImage = new URL(ogImageSrc, Astro.site);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="theme-color" content="#f97316" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-inter" preload />
<Font cssVariable="--font-jetbrains" />

<link rel="canonical" href={canonicalURL} />
<title>{pageTitle}</title>
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />

<!-- GoatCounter analytics (privacy-friendly, no cookies). is:inline keeps Astro
     from bundling it so the data-attribute + async load stay intact. -->
<script
	is:inline
	data-goatcounter="https://greenwoodms06.goatcounter.com/count"
	async
	src="//gc.zgo.at/count.js"></script>
