---
// Sticky "On this page" nav built from an article's h2/h3 headings.
// Astro auto-assigns id slugs to markdown headings, so #slug anchors just work.
import type { MarkdownHeading } from 'astro';

interface Props {
	headings: MarkdownHeading[];
	minutes?: number;
}

const { headings, minutes } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
	toc.length > 0 && (
		<nav aria-label="Table of contents" class="sticky top-24 text-sm">
			<p class="font-mono text-xs uppercase tracking-wide text-zinc-400">
				On this page
			</p>
			<ul class="mt-3 space-y-2 border-l border-zinc-200 dark:border-zinc-800">
				{toc.map((h) => (
					<li>
						<a
							href={`#${h.slug}`}
							data-toc-link={h.slug}
							class:list={[
								'toc-link -ml-px block border-l border-transparent pl-3 text-zinc-500 transition hover:border-accent hover:text-accent',
								h.depth === 3 && 'pl-6 text-[0.8rem]',
							]}
						>
							{h.text}
						</a>
					</li>
				))}
			</ul>
			{minutes && (
				<p class="mt-4 pl-3 font-mono text-xs text-zinc-400">{minutes} min read</p>
			)}
		</nav>
	)
}

<script>
	// Scroll-spy: mark the TOC link whose section is currently in view.
	const links = [
		...document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'),
	];
	if (links.length) {
		const targets = links
			.map((l) => document.getElementById(l.dataset.tocLink!))
			.filter((el): el is HTMLElement => el !== null);

		const activate = (id: string) =>
			links.forEach((l) =>
				l.classList.toggle('is-active', l.dataset.tocLink === id),
			);

		const observer = new IntersectionObserver(
			(entries) => {
				const onscreen = entries.filter((e) => e.isIntersecting);
				if (onscreen.length) activate(onscreen[0].target.id);
			},
			{ rootMargin: '0px 0px -70% 0px', threshold: 1 },
		);
		targets.forEach((t) => observer.observe(t));
	}
</script>
